# One MySQL server can be shared with Jeepay, but keep this app in a separate database.
# Example: mysql://buyweb:buyweb_dev@127.0.0.1:3306/buyweb
DATABASE_URL="mysql://buyweb:buyweb_dev@127.0.0.1:3306/buyweb"

# Use a long random value in production.
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Seed account used by `npm run db:seed`.
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_PASSWORD="Admin@123456"

# Public URL used in Jeepay notifyUrl and returnUrl.
# Use http://host.docker.internal:3000 when Jeepay runs in Docker on Windows
# and buy_web runs on the Windows host.
APP_PUBLIC_URL="http://localhost:3000"

# Local development defaults to mock payment. Change to jeepay after the gateway is running.
PAYMENT_PROVIDER="mock"
JEEPAY_GATEWAY_URL="https://pay.example.com"
JEEPAY_MCH_NO=""
JEEPAY_APP_ID=""
JEEPAY_APP_SECRET=""

# Security controls. Keep TRUSTED_PROXY_COUNT aligned with the number of trusted reverse proxies before Next.js.
TRUSTED_PROXY_COUNT="1"
REGISTRATION_DISABLED="false"
ORDER_WRITE_DISABLED="false"
PAYMENT_WRITE_DISABLED="false"
SECURITY_EVENT_RETENTION_DAYS="90"

# MySQL backup scripts. Use a Linux path on the production VPS.
MYSQL_BACKUP_DIR="/var/backups/buyweb"
MYSQL_BACKUP_RETENTION_DAYS="14"

# Optional restore-drill target for `npm run backup:verify`; must point to a temporary database.
MYSQL_VERIFY_DATABASE_URL=""
